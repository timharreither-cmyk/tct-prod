{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/posts/:id", "destination": "/api/posts?id=:id" },
    { "source": "/api/events/:id", "destination": "/api/events?id=:id" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
